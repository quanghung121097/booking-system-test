# ── Docker — file mẫu (KHÔNG commit file .env thật) ─────────────────────────
#
# Sau khi pull code, copy file này và tự điền mật khẩu:
#
#   cp .env.docker.example .env
#   cp .env.docker.example backend/.env
#
# .env (thư mục gốc)  → docker-compose dùng DB_* khi tạo container MySQL
# backend/.env        → Laravel đọc cấu hình ứng dụng
#
# Hai file phải dùng cùng DB_USERNAME / DB_PASSWORD / DB_ROOT_PASSWORD.

# App
APP_NAME="Booking System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database (giữ mặc định cho local dev hoặc tự đổi)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=booking_db
DB_USERNAME=booking_user
DB_PASSWORD=booking_pass
DB_ROOT_PASSWORD=secret

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8080
SESSION_DOMAIN=localhost

# Frontend
FRONTEND_URL=http://localhost:8080
