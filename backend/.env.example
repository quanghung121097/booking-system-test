# ── Local (không Docker) — file mẫu ─────────────────────────────────────────
#
#   cp .env.example .env
#
# Rồi điền APP_KEY (php artisan key:generate), DB_* và mật khẩu MySQL của bạn.
# Chạy Docker? Dùng .env.docker.example ở thư mục gốc thay vì file này.

# App
APP_NAME="Booking System"
APP_ENV=local
APP_KEY=base64:ck/FqxwsKsfNZpXDj5H68V6uXv6WYHjhyM6tQ29xhV4=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=booking_db
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_ROOT_PASSWORD=your_root_password

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:5173
SESSION_DOMAIN=localhost

# Frontend
FRONTEND_URL=http://localhost:5173

